{
  "name": "create-hana",
  "type": "module",
  "version": "0.1.0",
  "packageManager": "pnpm@10.32.1",
  "description": "A modern project scaffolding tool for JS/TS applications",
  "author": "non_hana",
  "license": "MIT",
  "keywords": [
    "cli",
    "scaffold",
    "generator",
    "typescript",
    "javascript",
    "nodejs"
  ],
  "main": "dist/index.mjs",
  "bin": {
    "create-hana": "dist/index.mjs"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsdown",
    "dev": "tsx src/index.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@clack/prompts": "catalog:",
    "@vue/compiler-sfc": "catalog:",
    "cross-spawn": "catalog:",
    "mri": "catalog:",
    "picocolors": "catalog:",
    "recast": "catalog:"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:",
    "@babel/parser": "catalog:",
    "@babel/types": "catalog:",
    "@changesets/cli": "catalog:",
    "@types/node": "catalog:",
    "@vitest/ui": "catalog:",
    "eslint": "catalog:",
    "tsdown": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}
